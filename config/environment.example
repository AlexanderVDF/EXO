# Variables d'environnement pour l'Assistant Personnel
# Copiez ce fichier et configurez vos valeurs

# 🔑 API Claude Anthropic (OBLIGATOIRE)
# Obtenez votre clé sur: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 🎯 Configuration Claude
CLAUDE_MODEL=claude-3-haiku-20240307
CLAUDE_MAX_TOKENS=1024

# 🔊 Configuration Audio
ALSA_CARD=0
PULSE_RUNTIME_PATH=/run/user/1000/pulse

# 🖥️ Configuration Affichage
QT_QPA_PLATFORM=eglfs
QT_QUICK_CONTROLS_STYLE=Material
QT_QUICK_CONTROLS_MATERIAL_THEME=Dark

# 📊 Monitoring
SYSTEM_LOG_LEVEL=INFO
ENABLE_PERFORMANCE_MONITORING=true

# 🌐 Réseau
NETWORK_TIMEOUT=30
HEALTH_CHECK_INTERVAL=60

# 🏠 Chemins système
ASSISTANT_HOME=/opt/raspberry-assistant
ASSISTANT_CONFIG_DIR=/opt/raspberry-assistant/config
ASSISTANT_LOG_DIR=/var/log/raspberry-assistant