# Configuration Assistant Domotique v2.0
# Fichier de configuration principal pour tous les services

# ================================
# CLAUDE HAIKU (OBLIGATOIRE)
# ================================
# Obtenez votre clé sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI
CLAUDE_MODEL=claude-3-haiku-20240307
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7

# ================================
# MICROSOFT AZURE TTS HENRI
# ================================
# Obtenez vos clés sur : https://azure.microsoft.com/cognitive-services/
AZURE_TTS_KEY=VOTRE_CLE_AZURE_ICI
AZURE_TTS_REGION=francecentral
AZURE_VOICE=fr-FR-HenriNeural
AZURE_TTS_QUALITY=high

# ================================
# EZVIZ SMART HOME
# ================================
# Obtenez vos clés sur : https://open.ys7.com/
EZVIZ_APP_KEY=VOTRE_APP_KEY_EZVIZ
EZVIZ_APP_SECRET=VOTRE_APP_SECRET_EZVIZ
EZVIZ_ACCOUNT=votre.email@exemple.com
EZVIZ_PASSWORD=votre_mot_de_passe_ezviz

# ================================
# SPOTIFY STREAMING
# ================================
# Obtenez vos clés sur : https://developer.spotify.com/
SPOTIFY_CLIENT_ID=VOTRE_CLIENT_ID_SPOTIFY
SPOTIFY_CLIENT_SECRET=VOTRE_CLIENT_SECRET_SPOTIFY
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ================================
# TIDAL STREAMING
# ================================
# Obtenez vos clés sur : https://developer.tidal.com/
TIDAL_CLIENT_ID=VOTRE_CLIENT_ID_TIDAL
TIDAL_CLIENT_SECRET=VOTRE_CLIENT_SECRET_TIDAL

# ================================
# OPENWEATHERMAP MÉTÉO
# ================================
# Obtenez votre clé gratuite sur : https://openweathermap.org/api
OPENWEATHER_API_KEY=VOTRE_CLE_OPENWEATHER_ICI
WEATHER_CITY=Paris
WEATHER_UPDATE_INTERVAL=600

# ================================
# GOOGLE SERVICES
# ================================
# Obtenez vos clés sur : https://console.cloud.google.com/
GOOGLE_CLIENT_ID=VOTRE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=VOTRE_CLIENT_SECRET_GOOGLE
GOOGLE_API_KEY=VOTRE_API_KEY_GOOGLE

# ================================
# CONFIGURATION SYSTÈME
# ================================
# Répertoires
APP_DATA_DIR=/home/pi/.raspberry-assistant
LOG_LEVEL=INFO
DEBUG_MODE=false

# Audio
AUDIO_INPUT_DEVICE=default
AUDIO_OUTPUT_DEVICE=default
DEFAULT_VOLUME=0.7

# Interface
DISPLAY_WIDTH=1920
DISPLAY_HEIGHT=1080
FULLSCREEN=true
TOUCHSCREEN_ENABLED=true

# Base de données
DATABASE_PATH=/home/pi/.raspberry-assistant/memory.db
CACHE_SIZE_MB=100
DATA_RETENTION_DAYS=365

# Réseau
HTTP_TIMEOUT=30
WEBSOCKET_TIMEOUT=10
MAX_RETRY_ATTEMPTS=3